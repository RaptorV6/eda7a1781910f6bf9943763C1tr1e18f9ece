    <certificateManager>
      <certificates>
        <clear />
        <add id="cb7c59bf-adc2-4823-b129-6a3d3901f818" thumb="A3A6EA6E58C0352E7071AA1F811F4597C40010A3" />
        <add id="6ead4faf-77d9-465e-8e7a-5061b58eade0" thumb="1230C3B9FB690C900333CB94BC24992145986E3E" />
      </certificates>
    </certificateManager>
    <tokenManager>
      <services>
        <clear />
        <service id="da1c301a-a46f-4389-8796-fc7ad1250545" displayName="Dazzle Resource Consumer">
          <relyingParties signingId="_" defaultLifetime="01:00:00" maxLifetime="01:00:00">
            <clear />
          </relyingParties>
          <trustedIssuers decipherId="cb7c59bf-adc2-4823-b129-6a3d3901f818">
