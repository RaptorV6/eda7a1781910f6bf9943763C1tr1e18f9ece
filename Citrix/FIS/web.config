    <delegatedKerberosAuthentication>
      <clientEndpoint uri="net.pipe://localhost/Citrix/Authentication/Kerberos" authenticationMode="windows" clientOpenTimeout="00:01:00" clientCloseTimeout="00:00:10" clientSendTimeout="00:01:00" />
    </delegatedKerberosAuthentication>
  </citrix.deliveryservices>
  <appSettings />
  <system.web>
    <!-- minFreeThreads = 88 * N and minLocalRequestFreeThreads = 76 * N where N is the number of logical CPUs -->
    <httpRuntime targetFramework="4.8" executionTimeout="300" appRequestQueueLimit="100" maxRequestLength="4096" enableVersionHeader="false" requestValidationMode="2.0" minFreeThreads="176" minLocalRequestFreeThreads="152" />
    <!-- FIPS 140-1 -->
    <machineKey validationKey="AutoGenerate,IsolateApps" decryptionKey="AutoGenerate,IsolateApps" validation="HMACSHA256" decryption="AES" />
    <compilation debug="false" targetFramework="4.8" />
    <customErrors mode="RemoteOnly" />
    <!-- Tracing enabled for locahost only, writing to the .Net diagnostic tracer. -->
    <trace enabled="false" localOnly="true" pageOutput="false" requestLimit="10" mostRecent="true" writeToDiagnosticsTrace="true" traceMode="SortByTime" />
    <sessionState mode="Off" />
    <caching>
      <outputCacheSettings>
        <outputCacheProfiles>
          <add name="NoCache" location="None" varyByParam="none" noStore="true" />
        </outputCacheProfiles>
      </outputCacheSettings>
    </caching>
  </system.web>
