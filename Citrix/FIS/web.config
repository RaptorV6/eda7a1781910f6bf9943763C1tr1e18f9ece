    </delegatedExplicitAuthentication>
    <dazzleResources>
      <routeTable order="10">
        <routes>
          <route name="listresources" order="1" url="resources/v2/withoutautoprovision">
            <defaults>
              <add param="controller" value="DazzleResources" />
              <add param="action" value="ListWithoutAutoProvision" />
            </defaults>
            <data>
              <add name="endpointId" value="ListResources" />
              <add name="endpointCapabilities" value="ResourcesEnumerationV2,group:core,group:desktop,group:status,group:fta,group:launch,group:keywords,group:images,group:icon,group:vm,group:sub,group:workflow,group:fmd" />
              <add name="CommonData" factory="Citrix.DeliveryServices.Configuration.ObjectCollectionFactory, Citrix.DeliveryServices.Configuration, Version=3.33.0.0, Culture=neutral, PublicKeyToken=e8b77d454fa2a856" path="citrix.deliveryservices/dazzleResources" property="commonData" />
            </data>
          </route>
          <route name="listwithautoprovision" order="2" url="resources/v2">
            <defaults>
              <add param="controller" value="DazzleResources" />
