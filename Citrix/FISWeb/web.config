        <add name="rfWebGeneric" key="/cpMmSg+ytdtdfOCG7nYNyj65WbkjTSltLRXVTagToHd/wU1s9bohkNM/kDVlHn5eUdMHeG9qvutKrsCBCLu2Q==" />
      </hmac>
    </cryptography>
    <delegatedKerberosAuthentication>
      <clientEndpoint uri="net.pipe://localhost/Citrix/Authentication/Kerberos" authenticationMode="windows" clientOpenTimeout="00:01:00" clientCloseTimeout="00:00:10" clientSendTimeout="00:01:00" />
    </delegatedKerberosAuthentication>
    <certificateManager>
      <certificates>
        <clear />
        <add id="8996236c-17d5-416a-9fba-a2f8d91e11ae" thumb="581F3D8F2CDD64174A03F43E018E9FB27C52B81A" />
        <add id="6ead4faf-77d9-465e-8e7a-5061b58eade0" thumb="1230C3B9FB690C900333CB94BC24992145986E3E" />
      </certificates>
    </certificateManager>
    <tokenManager>
      <services>
        <clear />
        <service id="20edeb55-6d3e-430c-9914-9859c1f4c030" displayName="Receiver for Web Token Producer">
          <relyingParties signingId="8996236c-17d5-416a-9fba-a2f8d91e11ae"
            defaultLifetime="01:00:00" maxLifetime="01:00:00">
            <clear />
            <add id="7ddeadb6-aeb0-43eb-a1d6-63bb70ed7389" encipherId="6ead4faf-77d9-465e-8e7a-5061b58eade0"
