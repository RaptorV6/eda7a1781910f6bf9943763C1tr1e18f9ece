    </components>
  </container>
  <citrix.deliveryservices>
    <routing hostBaseUrl="https://10.193.32.209/" serviceName="FISAuth">
      <externalEndpoints>
        <clear />
      </externalEndpoints>
    </routing>
    <defaultRoutes>
      <routeTable order="0">
        <ignoreroutes>
          <clear />
          <route name="ignore" url="{resource}.axd/{*pathInfo}" />
        </ignoreroutes>
        <routes>
          <clear />
          <route name="endpoints" order="1" url="endpoints/v1">
            <defaults>
              <add param="controller" value="Endpoints" />
              <add param="action" value="Endpoints" />
            </defaults>
            <data>
              <add name="endpointId" value="Endpoints" />
              <add name="endpointCapabilities" value="endpoints" />
            </data>
          </route>
          <route name="cw-monitor" order="50" url="svcmon/credentialwallet">
            <defaults>
              <add param="controller" value="ServiceMonitor" />
              <add param="action" value="CredentialWalletMonitor" />
            </defaults>
            <data />
          </route>
        </routes>
      </routeTable>
    </defaultRoutes>
    <localisation>
      <resourceSets>
        <clear />
        <add prefix="FormsProtocol" resourcePath="App_Data/resources/FormsProtocol" />
        <add prefix="ExplicitCore" resourcePath="App_Data/resources/ExplicitCore" />
        <add prefix="ExplicitJson" resourcePath="App_Data/resources/ExplicitJson" />
        <add prefix="ExplicitFormsCommon" resourcePath="App_Data/resources/ExplicitFormsCommon" />
        <add prefix="ExplicitAuth" resourcePath="App_Data/resources/ExplicitAuth" />
        <add prefix="SamlForms" resourcePath="App_Data/resources/SamlForms" />
      </resourceSets>
    </localisation>
    <logger duplicateInterval="00:01:00" duplicateLimit="10">
      <logConsumers>
        <clear />
