            <add id="7ddeadb6-aeb0-43eb-a1d6-63bb70ed7389" location="https://10.193.32.209/Citrix/FISAuth/auth/v1/token"
              verifyId="6ead4faf-77d9-465e-8e7a-5061b58eade0" />
          </trustedIssuers>
