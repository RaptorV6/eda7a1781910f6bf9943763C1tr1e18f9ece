            <add name="requestFilter" value="CitrixAGBasicRequestFilterPasswordNotRequired" />
          </properties>
        </add>
      </authenticationProtocolChoices>
      <entraIDSettings tenantId="" citrixIdentityCustomer="" graphApiUrl="https://graph.microsoft.com/v1.0"
        graphApiTimeoutSeconds="5" totalGraphApiTimeoutSeconds="100"
        authorityUrl="https://login.microsoftonline.com/" alwaysForceLogon="true"
        enabled="false" />
      <routeTable order="0">
        <routes>
          <clear />
          <route name="tokenservice" url="auth/v1/token">
            <defaults>
              <add param="controller" value="AuthService" />
              <add param="action" value="TokenServices" />
            </defaults>
            <data>
              <add name="ServiceRootHint" value="/auth/v1/token" />
              <add name="endpointId" value="TokenService" />
              <add name="endpointCapabilities" value="tokenIssue,tokenRefresh,tokenDestroy" />
            </data>
          </route>
          <route name="protocols" url="auth/v1/protocols">
            <defaults>
              <add param="controller" value="Protocols" />
              <add param="action" value="Choices" />
            </defaults>
          </route>
          <route name="tokenValidationService" url="auth/v1/token/validate/{tokenValidationServiceId}">
            <defaults>
              <add param="controller" value="TokenValidation" />
              <add param="action" value="TokenValidation" />
              <add param="tokenValidationServiceId" value="default" />
            </defaults>
            <data>
              <add name="endpointId" value="TokenValidationService" />
              <add name="endpointCapabilities" value="tokenValidation" />
            </data>
          </route>
        </routes>
      </routeTable>
    </authenticationService>
    <returnStoreServerName enabled="true" />
    <fasResilienceConfiguration enabled="true" numberOfExceptionsBeforeBreak="3"
      durationOfBreakInMinutes="5" />
    <delegatedExplicitAuthentication>
      <clientEndpoint uri="net.pipe://localhost/Citrix/Authentication/Win32" authenticationMode="windows" clientOpenTimeout="00:01:00" clientCloseTimeout="00:00:10" clientSendTimeout="00:01:00" />
    </delegatedExplicitAuthentication>
    <explicitJsonRoutes>
      <routeTable order="0">
        <routes>
          <route name="JSONExplicitAuthentication" url="ExplicitJson">
            <defaults>
              <add param="controller" value="ExplicitJson" />
              <add param="action" value="Authenticate" />
            </defaults>
            <data>
              <add name="endpointId" value="ExplicitJsonAuth" />
              <add name="endpointCapabilities" value="authenticate,changePassword" />
            </data>
          </route>
        </routes>
      </routeTable>
    </explicitJsonRoutes>
    <explicitBL authenticator="defaultDelegatedAuthenticator" requireAccountSIDs="true"
      hideDomainField="false" allowUserPasswordChange="Never" showPasswordExpiryWarning="Windows"
      passwordExpiryWarningPeriod="10" explicitJsonEnabled="true"
      allowZeroLengthPassword="false">
      <domainSelection default="acr">
        <clear />
        <add domain="fis.acr" />
