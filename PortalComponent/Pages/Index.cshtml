@page
@model IndexModel
@{
    ViewData["Title"] = Model.PanelTitle;
    var configuredBaseUrl = string.IsNullOrWhiteSpace(Model.CitrixBaseUrl)
        ? "Není nastaveno"
        : Model.CitrixBaseUrl;
}

<style>
    .citrix-diagnostics-panel {
        border: 1px solid #d9e2ec;
        border-radius: 1rem;
        background: #ffffff;
        box-shadow: 0 1rem 2rem rgba(15, 23, 42, 0.06);
        padding: 1.5rem;
    }

    .citrix-diagnostics-title {
        margin-bottom: 0.25rem;
        font-size: 1.75rem;
        font-weight: 700;
    }

    .citrix-diagnostics-subtitle {
        color: #52606d;
        margin-bottom: 0;
    }

    .citrix-diagnostics-note {
        margin: 1rem 0;
        border-radius: 0.75rem;
        background: #f8fafc;
        border: 1px solid #d9e2ec;
        padding: 0.85rem 1rem;
        color: #243b53;
    }

    .citrix-diagnostics-meta {
        margin-bottom: 1rem;
        color: #52606d;
        word-break: break-word;
    }

    .citrix-diagnostics-status {
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .citrix-diagnostics-status[data-level="info"] {
        color: #0f172a;
    }

    .citrix-diagnostics-status[data-level="warn"] {
        color: #b45309;
    }

    .citrix-diagnostics-status[data-level="error"] {
        color: #b42318;
    }

    .citrix-diagnostics-status[data-level="success"] {
        color: #047857;
    }

    .citrix-login-form {
        margin-bottom: 1rem;
        border: 1px solid #d9e2ec;
        border-radius: 0.85rem;
        background: #f8fafc;
        padding: 1rem;
    }

    .citrix-login-grid {
        display: grid;
        gap: 0.85rem;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .citrix-login-field {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .citrix-login-field label {
        font-weight: 600;
        color: #243b53;
    }

    .citrix-login-field input {
        border: 1px solid #cbd5e1;
        border-radius: 0.65rem;
        padding: 0.7rem 0.8rem;
        background: #ffffff;
    }

    .citrix-login-actions {
        margin-top: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .citrix-login-button {
        border: 0;
        border-radius: 0.65rem;
        background: #0f766e;
        color: #ffffff;
        font-weight: 700;
        padding: 0.75rem 1rem;
    }

    .citrix-login-button:disabled {
        opacity: 0.6;
        cursor: wait;
    }

    .citrix-login-hint {
        color: #52606d;
        font-size: 0.95rem;
    }

    .citrix-app-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.75rem;
    }

    .citrix-app-item {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 0.85rem 1rem;
        border-radius: 0.85rem;
        border: 1px solid #d9e2ec;
        background: #f8fafc;
    }

    .citrix-app-icon {
        width: 42px;
        height: 42px;
        object-fit: contain;
        border-radius: 0.65rem;
        border: 1px solid #cbd5e1;
        background: #ffffff;
        padding: 0.25rem;
        flex-shrink: 0;
    }

    .citrix-app-name {
        font-weight: 600;
        color: #102a43;
    }

    .citrix-empty-state {
        color: #52606d;
        margin-bottom: 0;
    }

    .citrix-diagnostics-log {
        margin-top: 1rem;
        margin-bottom: 0;
        padding: 1rem;
        min-height: 18rem;
        max-height: 30rem;
        overflow: auto;
        border-radius: 0.85rem;
        background: #0f172a;
        color: #e2e8f0;
        white-space: pre-wrap;
        font-size: 0.875rem;
        line-height: 1.45;
    }
</style>

<div id="citrix-diagnostics-root"
     class="citrix-diagnostics-panel"
     data-base-url="@Model.CitrixBaseUrl"
     data-panel-title="@Model.PanelTitle"
     data-body-preview-limit="@Model.BodyPreviewLimit"
     data-client-log-endpoint="@Model.ClientLogEndpoint"
     data-server-probe-endpoint="@Model.ServerProbeEndpoint"
     data-server-login-endpoint="@Model.ServerLoginEndpoint"
     data-request-id="@Model.DiagnosticRequestId">
    <div class="mb-3">
        <h1 class="citrix-diagnostics-title">@Model.PanelTitle</h1>
        <p class="citrix-diagnostics-subtitle">Minimalní diagnostický PoC pro ověření StoreFront Web API a načtení aplikací uživatele.</p>
    </div>

    <div class="citrix-diagnostics-note">
        Nejdřív se přihlaste do StoreFrontu ve stejném browseru a na stejné Citrix URL. Přihlášení jen v nativní Citrix Workspace app nemusí dodat browser cookies pro tento PoC.
    </div>

    <div class="citrix-diagnostics-meta">
        Použitá Citrix URL:
        <code id="citrix-base-url">@configuredBaseUrl</code>
    </div>

    <form id="citrix-login-form" class="citrix-login-form">
        <div class="citrix-login-grid">
            <div class="citrix-login-field">
                <label for="citrix-username">Uživatelské jméno</label>
                <input id="citrix-username" name="username" type="text" autocomplete="username" spellcheck="false" />
            </div>
            <div class="citrix-login-field">
                <label for="citrix-password">Heslo</label>
                <input id="citrix-password" name="password" type="password" autocomplete="current-password" />
            </div>
            <div class="citrix-login-field">
                <label for="citrix-domain">Doména</label>
                <input id="citrix-domain" name="domain" type="text" value="acr" spellcheck="false" />
            </div>
        </div>
        <div class="citrix-login-actions">
            <button id="citrix-login-button" class="citrix-login-button" type="submit">Přihlásit přes localhost</button>
            <span class="citrix-login-hint">Credentials se odešlou jen na náš ASP.NET endpoint, který provede Citrix login na serveru.</span>
        </div>
    </form>

    <div id="citrix-status" class="citrix-diagnostics-status" data-level="info">Načítám Citrix konfiguraci…</div>

    <div id="citrix-apps">
        <ul id="citrix-app-list" class="citrix-app-list"></ul>
        <p id="citrix-empty-state" class="citrix-empty-state d-none"></p>
    </div>

    <pre id="citrix-log" class="citrix-diagnostics-log"></pre>
</div>

@section Scripts {
    <script>
        (() => {
            const root = document.getElementById('citrix-diagnostics-root');
            if (!root) {
                return;
            }

            const statusElement = document.getElementById('citrix-status');
            const appListElement = document.getElementById('citrix-app-list');
            const emptyStateElement = document.getElementById('citrix-empty-state');
            const logElement = document.getElementById('citrix-log');
            const loginFormElement = document.getElementById('citrix-login-form');
            const usernameElement = document.getElementById('citrix-username');
            const passwordElement = document.getElementById('citrix-password');
            const domainElement = document.getElementById('citrix-domain');
            const loginButtonElement = document.getElementById('citrix-login-button');

            const rawBaseUrl = (root.dataset.baseUrl || '').trim();
            const normalizedBaseUrl = rawBaseUrl ? rawBaseUrl.replace(/\/?$/, '/') : '';
            const bodyPreviewLimit = Number.parseInt(root.dataset.bodyPreviewLimit || '1200', 10) || 1200;
            const clientLogEndpoint = root.dataset.clientLogEndpoint || '';
            const serverProbeEndpoint = root.dataset.serverProbeEndpoint || '';
            const serverLoginEndpoint = root.dataset.serverLoginEndpoint || '';
            const requestId = root.dataset.requestId || `client-${Date.now()}`;
            let clientLogSequence = 0;

            const setStatus = (message, level) => {
                statusElement.textContent = message;
                statusElement.dataset.level = level;
            };

            const appendLogLine = (level, message) => {
                const timestamp = new Date().toISOString();
                logElement.textContent += `[${timestamp}] [${level}] ${message}\n`;
                logElement.scrollTop = logElement.scrollHeight;
            };

            const sendServerLog = async (level, step, message) => {
                if (!clientLogEndpoint) {
                    return;
                }

                try {
                    const response = await fetch(clientLogEndpoint, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            requestId,
                            level,
                            step,
                            message: `#${++clientLogSequence} ${message}`,
                            browserTimestamp: new Date().toISOString(),
                            pagePath: window.location.pathname
                        })
                    });

                    if (!response.ok) {
                        appendLogLine('WARN', `Server log mirror failed with status ${response.status}.`);
                    }
                } catch (error) {
                    appendLogLine('WARN', `Server log mirror fetch failed: ${error instanceof Error ? error.message : String(error)}`);
                }
            };

            const writeLog = (level, step, message, consoleWriter) => {
                consoleWriter(`[${step}] ${message}`);
                appendLogLine(level, `${step}: ${message}`);
                void sendServerLog(level, step, message);
            };

            const log = {
                info(step, message) {
                    writeLog('INFO', step, message, console.log);
                },
                warn(step, message) {
                    writeLog('WARN', step, message, console.warn);
                },
                error(step, message) {
                    writeLog('ERROR', step, message, console.error);
                }
            };

            const truncate = (value) => {
                if (value == null) {
                    return '';
                }

                const text = String(value);
                return text.length > bodyPreviewLimit
                    ? `${text.slice(0, bodyPreviewLimit)}... [zkráceno]`
                    : text;
            };

            const getSafeJsonPreview = (value) => {
                try {
                    return truncate(JSON.stringify(value, null, 2));
                } catch (error) {
                    return `JSON preview selhal: ${error instanceof Error ? error.message : String(error)}`;
                }
            };

            const logMultilineBlock = (stepName, label, value) => {
                if (!value) {
                    return;
                }

                log.info(stepName, `${label}:\n${truncate(value)}`);
            };

            const getAccessibleHeaders = (response) => {
                const headers = {};

                response.headers.forEach((value, key) => {
                    headers[key] = value;
                });

                return headers;
            };

            const getCookieValue = (cookieName) => {
                const escapedName = cookieName.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                const match = document.cookie.match(new RegExp(`(?:^|; )${escapedName}=([^;]*)`));
                return match ? decodeURIComponent(match[1]) : '';
            };

            const joinUrl = (baseUrl, relativeOrAbsoluteUrl) => {
                try {
                    return new URL(relativeOrAbsoluteUrl, baseUrl).toString();
                } catch (error) {
                    log.warn('UrlJoin', `Nepodařilo se složit URL z hodnoty "${relativeOrAbsoluteUrl}": ${error instanceof Error ? error.message : String(error)}`);
                    return relativeOrAbsoluteUrl;
                }
            };

            const createTransactionId = () => {
                if (window.crypto && typeof window.crypto.randomUUID === 'function') {
                    return window.crypto.randomUUID();
                }

                return `diag-${Date.now()}-${Math.random().toString(16).slice(2)}`;
            };

            const createCitrixHeaders = ({ httpsHeaderValue, csrfToken = '', includeContentType = false } = {}) => {
                const headers = {
                    'Citrix-TransactionId': createTransactionId(),
                    'X-Citrix-IsUsingHTTPS': httpsHeaderValue,
                    'X-Requested-With': 'XMLHttpRequest'
                };

                if (includeContentType) {
                    headers['Content-Type'] = 'application/x-www-form-urlencoded; charset=UTF-8';
                }

                if (csrfToken) {
                    headers['Csrf-Token'] = csrfToken;
                }

                return headers;
            };

            const logResponse = (stepName, requestUrl, method, response, responseText) => {
                log.info(stepName, `request ${method} ${requestUrl}`);
                log.info(stepName, `status ${response.status} ${response.statusText || ''}`.trim());
                log.info(stepName, `redirected=${response.redirected}, finalUrl=${response.url || '(neznámé)'}`);
                log.info(stepName, `content-type=${response.headers.get('content-type') || '(neznámé)'}`);

                const headers = getAccessibleHeaders(response);
                if (Object.keys(headers).length > 0) {
                    log.info(stepName, `Čitelné response hlavičky: ${getSafeJsonPreview(headers)}`);
                }

                const challengeHeader = response.headers.get('CitrixWebReceiver-Authenticate');
                if (challengeHeader) {
                    log.warn(stepName, `CitrixWebReceiver-Authenticate=${challengeHeader}`);
                }

                const preview = truncate(responseText);
                if (preview) {
                    log.info(stepName, `body preview=${preview}`);
                } else {
                    log.info(stepName, 'body preview je prázdný.');
                }
            };

            const runProbe = async (stepName, requestUrl, requestOptions) => {
                log.info(stepName, `Spouštím request ${requestOptions.method || 'GET'} ${requestUrl}`);

                const response = await fetch(requestUrl, requestOptions).catch((error) => {
                    log.error(stepName, `Fetch selhal: ${error instanceof Error ? error.message : String(error)}`);
                    throw error;
                });

                const responseText = await response.text();
                logResponse(stepName, requestUrl, requestOptions.method || 'GET', response, responseText);

                if (looksLikeUnauthorized(response, responseText)) {
                    log.warn(stepName, 'Odpověď vypadá jako unauthorized / auth challenge / redirect na login.');
                }

                return {
                    response,
                    responseText
                };
            };

            const runServerSideProbe = async (stepName, requestUrl, requestOptions) => {
                if (!serverProbeEndpoint) {
                    log.warn(stepName, 'Server-side probe endpoint není nastaven.');
                    return null;
                }

                const normalizedHeaders = {};
                const sourceHeaders = requestOptions.headers || {};

                if (sourceHeaders instanceof Headers) {
                    sourceHeaders.forEach((value, key) => {
                        normalizedHeaders[key] = value;
                    });
                } else {
                    Object.assign(normalizedHeaders, sourceHeaders);
                }

                const bodyValue = typeof requestOptions.body === 'string'
                    ? requestOptions.body
                    : requestOptions.body instanceof URLSearchParams
                        ? requestOptions.body.toString()
                        : requestOptions.body == null
                            ? ''
                            : String(requestOptions.body);

                log.info(stepName, `Spouštím server-side probe přes ${serverProbeEndpoint}`);

                try {
                    const response = await fetch(serverProbeEndpoint, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            requestId,
                            step: stepName,
                            storeRootUrl: normalizedBaseUrl,
                            url: requestUrl,
                            method: requestOptions.method || 'GET',
                            body: bodyValue,
                            contentType: normalizedHeaders['Content-Type'] || normalizedHeaders['content-type'] || '',
                            headers: normalizedHeaders
                        })
                    });

                    const probeText = await response.text();
                    let probePayload = null;

                    try {
                        probePayload = JSON.parse(probeText);
                    } catch (error) {
                        log.error(stepName, `Server-side probe vrátil nevalidní JSON: ${truncate(probeText)}`);
                        return null;
                    }

                    log.info(stepName, `Server-side probe výsledek: ${getSafeJsonPreview(probePayload)}`);
                    return probePayload;
                } catch (error) {
                    log.error(stepName, `Server-side probe selhal: ${error instanceof Error ? error.message : String(error)}`);
                    return null;
                }
            };

            const explainServerSideProbe = (stepName, probePayload) => {
                if (!probePayload) {
                    return;
                }

                const bootstrapLocation = probePayload.bootstrapHeaders?.Location || probePayload.bootstrapHeaders?.location || '';

                if (probePayload.bootstrapStatusCode === 302 && bootstrapLocation) {
                    log.warn(stepName, `Bootstrap store root skončil redirectem na ${bootstrapLocation}`);
                }

                if (probePayload.bootstrapStatusCode === 302
                    && probePayload.bootstrapCsrfTokenFound === false
                    && Array.isArray(probePayload.bootstrapCookieNames)
                    && probePayload.bootstrapCookieNames.length > 0) {
                    log.warn(
                        stepName,
                        `Server-side probe má jen gateway cookies (${probePayload.bootstrapCookieNames.join(', ')}), ale nezískal StoreFront CsrfToken. To je nová neautentizovaná session, ne vaše browser session.`
                    );
                }

                if (probePayload.statusCode === 404 && probePayload.bootstrapCsrfTokenFound === false) {
                    log.warn(
                        stepName,
                        'HTTP 404 tady není hlavní problém. Hlavní problém je chybějící authenticated StoreFront session a CSRF token.'
                    );
                }

                if (window.location.origin !== new URL(normalizedBaseUrl).origin) {
                    log.warn(
                        stepName,
                        'PortalComponent běží na jiném originu než Citrix StoreFront. Browser requesty proto narážejí na CORS/SameSite. Pro skutečné načtení aplikací je potřeba same-origin hostování nebo serverový login/proxy.'
                    );
                }
            };

            const readAttributes = (xmlDocument, tagName, attributeNames) => {
                const element = xmlDocument.getElementsByTagName(tagName)[0];
                if (!element) {
                    return null;
                }

                const result = {};

                for (const attributeName of attributeNames) {
                    const attributeValue = element.getAttribute(attributeName);
                    if (attributeValue) {
                        result[attributeName] = attributeValue;
                    }
                }

                return Object.keys(result).length > 0 ? result : null;
            };

            const parseConfiguration = (xmlText) => {
                const parser = new DOMParser();
                const xmlDocument = parser.parseFromString(xmlText, 'application/xml');
                const parserError = xmlDocument.getElementsByTagName('parsererror')[0];

                if (parserError) {
                    throw new Error(parserError.textContent?.trim() || 'Neznámá chyba při parsování XML konfigurace.');
                }

                const configuration = {
                    authentication: readAttributes(xmlDocument, 'authentication', ['locationURL']),
                    authManager: readAttributes(xmlDocument, 'authManager', [
                        'getUsernameURL',
                        'getUserDetailsURL',
                        'logoffURL',
                        'changeCredentialsURL',
                        'webviewReturnURL',
                        'webviewResumeURL',
                        'allowSelfServiceAccountManagementURL'
                    ]),
                    resourcesProxy: readAttributes(xmlDocument, 'resourcesProxy', ['listURL', 'resourceDetails']),
                    protocolHandler: readAttributes(xmlDocument, 'protocolHandler', ['enabled']),
                    workspaceControl: readAttributes(xmlDocument, 'workspaceControl', ['enabled'])
                };

                const pluginAssistantElement = xmlDocument.getElementsByTagName('pluginAssistant')[0];
                if (pluginAssistantElement) {
                    const html5Element = pluginAssistantElement.getElementsByTagName('html5')[0];
                    if (html5Element) {
                        configuration.pluginAssistant = {
                            html5Enabled: html5Element.getAttribute('enabled') || ''
                        };
                    }
                }

                return configuration;
            };

            const renderApplications = (resources) => {
                appListElement.innerHTML = '';
                emptyStateElement.classList.add('d-none');
                emptyStateElement.textContent = '';

                for (const resource of resources) {
                    const iconUrl = resource.iconurl ? joinUrl(normalizedBaseUrl, resource.iconurl) : '';

                    const listItem = document.createElement('li');
                    listItem.className = 'citrix-app-item';

                    const image = document.createElement('img');
                    image.className = 'citrix-app-icon';
                    image.alt = resource.name || 'Citrix aplikace';
                    image.loading = 'lazy';
                    image.referrerPolicy = 'no-referrer';
                    image.src = iconUrl || 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==';
                    image.addEventListener('error', () => {
                        log.warn('IconLoad', `Ikona se nepodařila načíst pro aplikaci "${resource.name || '(bez názvu)'}": ${iconUrl || '(prázdná iconurl)'}`);
                    });

                    const name = document.createElement('div');
                    name.className = 'citrix-app-name';
                    name.textContent = resource.name || '(bez názvu)';

                    listItem.appendChild(image);
                    listItem.appendChild(name);
                    appListElement.appendChild(listItem);
                }
            };

            const showEmptyState = (message) => {
                appListElement.innerHTML = '';
                emptyStateElement.textContent = message;
                emptyStateElement.classList.remove('d-none');
            };

            const extractResources = (payload) => {
                if (Array.isArray(payload)) {
                    return payload;
                }

                if (Array.isArray(payload?.resources)) {
                    return payload.resources;
                }

                return null;
            };

            const looksLikeUnauthorized = (response, responseText) => {
                const body = (responseText || '').toLowerCase();
                const finalUrl = (response.url || '').toLowerCase();
                const challengeHeader = (response.headers.get('CitrixWebReceiver-Authenticate') || '').toLowerCase();

                return response.status === 401
                    || response.status === 403
                    || response.redirected
                    || challengeHeader.includes('tokenrequired')
                    || body.includes('"unauthorized":true')
                    || body.includes('"unauthorized": true')
                    || body.includes('getauthmethods')
                    || body.includes('explicitauth')
                    || body.includes('log on')
                    || finalUrl.includes('/authentication/')
                    || finalUrl.includes('/explicitauth/');
            };

            const setLoginFormDisabled = (disabled) => {
                if (!loginFormElement) {
                    return;
                }

                for (const element of loginFormElement.elements) {
                    element.disabled = disabled;
                }
            };

            const runServerSideLogin = async () => {
                if (!serverLoginEndpoint) {
                    throw new Error('Server login endpoint není nastaven.');
                }

                const username = (usernameElement?.value || '').trim();
                const password = passwordElement?.value || '';
                const domain = (domainElement?.value || '').trim();

                if (!username || !password || !domain) {
                    throw new Error('Vyplňte uživatelské jméno, heslo i doménu.');
                }

                log.info('ExplicitLogin', `Spouštím server-side explicit login přes ${serverLoginEndpoint}`);
                log.info('ExplicitLogin', `Odesílám username=${username}, domain=${domain}. Heslo se do logu nepropaguje.`);

                const response = await fetch(serverLoginEndpoint, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        requestId,
                        storeRootUrl: normalizedBaseUrl,
                        username,
                        password,
                        domain
                    })
                });

                const responseText = await response.text();
                let payload;

                try {
                    payload = JSON.parse(responseText);
                } catch (error) {
                    throw new Error(`Server login vrátil nevalidní JSON: ${truncate(responseText)}`);
                }

                log.info('ExplicitLogin', `Server-side explicit login výsledek: ${getSafeJsonPreview(payload)}`);
                return payload;
            };

            const explainExplicitLogin = (payload) => {
                if (!payload) {
                    return;
                }

                if (payload.bootstrapRedirectUrl) {
                    log.info('ExplicitLogin', `Bootstrap redirect URL: ${payload.bootstrapRedirectUrl}`);
                }

                if (payload.bootstrapFinalUrl) {
                    log.info('ExplicitLogin', `Bootstrap final URL: ${payload.bootstrapFinalUrl}`);
                }

                if (Array.isArray(payload.authMethodCandidates) && payload.authMethodCandidates.length > 0) {
                    log.info('ExplicitLogin', `Auth method kandidáti: ${payload.authMethodCandidates.join(' | ')}`);
                } else {
                    log.warn('ExplicitLogin', 'GetAuthMethods nevrátil žádný rozpoznaný auth endpoint.');
                }

                if (Array.isArray(payload.loginAttemptResults) && payload.loginAttemptResults.length > 0) {
                    payload.loginAttemptResults.forEach((attempt, index) => {
                        log.info('ExplicitLogin', `Login attempt ${index + 1}: ${attempt}`);
                    });
                }

                if (payload.authResult) {
                    log.info('ExplicitLogin', `Auth result: ${payload.authResult}`);
                }

                if (payload.loginErrorText) {
                    log.warn('ExplicitLogin', `Citrix error text: ${payload.loginErrorText}`);
                }

                logMultilineBlock('ExplicitLogin', 'AuthMethods preview', payload.authMethodsPreview);
                logMultilineBlock('ExplicitLogin', 'Bootstrap landing preview', payload.bootstrapLandingPreview);
                logMultilineBlock('ExplicitLogin', 'Login form preview', payload.loginFormPreview);
                logMultilineBlock('ExplicitLogin', 'Login submit preview', payload.loginSubmitPreview);
            };

            const handleLoginSubmit = async (event) => {
                event.preventDefault();

                appListElement.innerHTML = '';
                emptyStateElement.classList.add('d-none');
                emptyStateElement.textContent = '';

                try {
                    setLoginFormDisabled(true);
                    setStatus('Probíhá server-side Citrix login…', 'info');

                    const payload = await runServerSideLogin();
                    explainExplicitLogin(payload);

                    if (!payload.ok) {
                        throw new Error(payload.errorMessage || payload.message || 'Server-side Citrix login selhal.');
                    }

                    if (!payload.loginSucceeded) {
                        setStatus('Přihlášení do Citrixu nebylo dokončeno.', 'warn');
                        showEmptyState(payload.message || 'Citrix nevrátil success pro explicit login.');
                        return;
                    }

                    const resources = extractResources(payload.resourcesPayload);
                    if (!resources) {
                        setStatus('Přihlášení proběhlo, ale seznam aplikací není validní.', 'warn');
                        showEmptyState('Citrix login proběhl, ale Resources/List vrátil nečekaný formát.');
                        return;
                    }

                    if (resources.length === 0) {
                        setStatus('Přihlášení proběhlo, ale uživatel nemá žádné aplikace.', 'warn');
                        showEmptyState('Citrix login proběhl, ale seznam aplikací je prázdný.');
                        return;
                    }

                    renderApplications(resources);
                    setStatus(`Načteno ${resources.length} aplikací přes server-side login.`, 'success');
                    log.info('ExplicitLogin', `Aplikace byly načteny po explicit loginu. Počet: ${resources.length}`);
                } catch (error) {
                    const message = error instanceof Error ? error.message : String(error);
                    setStatus('Server-side Citrix login selhal.', 'error');
                    showEmptyState(message);
                    log.error('ExplicitLogin', message);
                } finally {
                    setLoginFormDisabled(false);
                }
            };

            const run = async () => {
                log.info('Init', 'JS init started');
                log.info('Init', `RequestId: ${requestId}`);
                log.info('Init', `Panel title: ${root.dataset.panelTitle || '(neznámý)'}`);
                log.info('Init', `Použitá Citrix URL: ${rawBaseUrl || '(není nastaveno)'}`);
                log.info('Init', `Normalizovaná Citrix URL: ${normalizedBaseUrl || '(není nastaveno)'}`);
                log.info('Init', `BodyPreviewLimit: ${bodyPreviewLimit}`);
                log.info('Init', `Client log endpoint: ${clientLogEndpoint || '(není nastaveno)'}`);
                log.info('Init', `Server probe endpoint: ${serverProbeEndpoint || '(není nastaveno)'}`);
                log.info('Init', `Server login endpoint: ${serverLoginEndpoint || '(není nastaveno)'}`);
                log.info('Init', `Browser origin: ${window.location.origin}`);
                log.info('Init', `Citrix URL origin: ${normalizedBaseUrl ? new URL(normalizedBaseUrl).origin : '(není nastaveno)'}`);

                if (!normalizedBaseUrl) {
                    setStatus('Citrix BaseUrl není nastavená.', 'error');
                    log.error('Init', 'Konfigurace CitrixDiagnostics:BaseUrl chybí. Requesty se nespustí.');
                    showEmptyState('Chybí konfigurace Citrix URL.');
                    return;
                }

                const httpsHeaderValue = normalizedBaseUrl.startsWith('https://') ? 'Yes' : 'No';
                log.info('Init', `X-Citrix-IsUsingHTTPS bude odeslán s hodnotou "${httpsHeaderValue}".`);
                log.info('Init', 'PortalComponent teď čeká na ručně odeslaný explicit login formulář. Browser už nezkouší přímé cross-origin fetch requesty do Citrixu.');

                if (loginFormElement) {
                    loginFormElement.addEventListener('submit', handleLoginSubmit);
                }

                setStatus('Vyplňte přihlášení a spusťte server-side Citrix login.', 'info');
                showEmptyState('Zatím nejsou načtené žádné aplikace. Přihlaste se přes formulář výše.');
            };

            run().catch((error) => {
                log.error('Run', `Běh diagnostického PoC skončil výjimkou: ${error instanceof Error ? error.message : String(error)}`);
            });
        })();
    </script>
}
