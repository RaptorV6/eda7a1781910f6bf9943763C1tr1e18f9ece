    <components>
      <component id="webApplicationStartupModule" type="Citrix.DeliveryServices.WebApplication.WebApplicationModule, Citrix.DeliveryServices.WebApplication" service="Citrix.DeliveryServices.Mvc.IStartupModule, Citrix.DeliveryServices.Mvc" />
