    </sectionGroup>
  </configSections>
  <citrix.deliveryservices>
    <webReceiver>
      <serverSettings>
        <authentication tokenLifeTime="10:00:00" locationURL="Authentication/GetAuthMethods">
          <authMethods>
            <clear />
            <add method="ExplicitForms" />
          </authMethods>
        </authentication>
        <communication attempts="1" timeout="00:05:00" loopback="OnUsingHttp"
          loopbackPortUsingHttp="80">
          <proxy enabled="false" processName="Fiddler" port="8888" />
        </communication>
        <discoveryService url="https://10.193.32.209/Citrix/FIS/discovery"
          runDiscoveryAtAppStart="true" />
        <resourcesService persistentIconCacheEnabled="true" icaFileCacheExpiry="90"
          iconSize="128" showDesktopViewer="false" />
        <appShortcuts promptForUntrustedShortcuts="true">
          <trustedUrls>
            <clear />
          </trustedUrls>
          <gatewayUrls>
            <clear />
          </gatewayUrls>
        </appShortcuts>
        <bundles>
          <clear />
        </bundles>
        <strictTransportSecurity enabled="false" policyDuration="90.00:00:00" />
        <csrfProtection excludedUserAgents="CitrixReceiver;CitrixWebAPI-NoCSRFToken" />
        <userInterfaceExperience experience="ReceiverForWeb" />
        <gacs enabled="false" serviceId="" tokenDuration="00:05:00" />
        <returnStoreServerName enabled="true" />
        <userNotifications enabled="false">
          <clear />
        </userNotifications>
        <blockingNotification enabled="false" frequency="FirstLogin">
          <default title="" body="" button="" />
        </blockingNotification>
        <ticketingServiceCorsPolicy allowedRedeemDomain="https://ctx-ws-assets.cloud.com" />
      </serverSettings>
      <clientSettings>
        <authManager getUsernameURL="Authentication/GetUserName" getUserDetailsURL="Authentication/GetUserDetails"
          logoffURL="Authentication/Logoff" changeCredentialsURL="ExplicitAuth/GetChangeCredentialForm"
          loginFormTimeout="60" webviewReturnURL="ExplicitAuth/Bounce"
          webviewResumeURL="ExplicitAuth/ResumeForms" allowSelfServiceAccountManagementURL="ExplicitAuth/AllowSelfServiceAccountManagement" />
        <storeProxy keepAliveURL="Home/KeepAlive">
          <resourcesProxy listURL="Resources/List" resourceDetails="default" />
          <sessionsProxy listAvailableURL="Sessions/ListAvailable" disconnectURL="Sessions/Disconnect"
            logoffURL="Sessions/Logoff" />
          <sessionControlProxy listSessionsURL="Sessions/List" logoffSessionsURL="Sessions/LogOffSessions"
            disconnectSessionsURL="Sessions/DisconnectSessions" />
          <machinesProxy powerOffMachineURL="Machines/PowerOff" shutDownMachineURL="Machines/ShutDown"
            suspendMachineURL="Machines/Suspend" listMachinesURL="Machines/List" />
          <clientAssistantProxy getDetectionTicketURL="ClientAssistant/GetDetectionTicket"
            getDetectionStatusURL="ClientAssistant/GetDetectionStatus" />
          <gacs gacsUrl="" gacsEndpointsUrl="" createTokenPath="Gacs/CreateToken" />
          <notifications blockingNotificationURL="Notifications/Blocking" />
          <serviceTicketsProxy getTicketsUrl="Tickets/ServiceTickets" />
        </storeProxy>
        <pluginAssistant enabled="false" upgradeAtLogin="false" showAfterLogin="false"
          allowSkipNativeAppDetection="true" requireNativeAppUse="false">
          <win32 path="https://downloadplugins.citrix.com/Windows/CitrixWorkspaceApp.exe" />
          <macOS path="https://downloadplugins.citrix.com/Mac/CitrixWorkspaceApp.dmg"
            minimumSupportedOSVersion="10.6" />
          <html5 enabled="Off" platforms="Firefox;Chrome;Version/([6-9]|\d\d).*Safari;MSIE \d\d;Trident/([6-9]|\d\d);Android;iPad;iPhone;iPod;"
            launchURL="clients/HTML5Client/src/SessionWindow.html" preferences=""
            singleTabLaunch="false" chromeAppOrigins="chrome-extension://haiffjcadagjlijoggckpgfnoeiflnem|chrome-extension://lbfgjakkeeccemhonnolnmglmfmccaag|chrome-extension://anjihnbmjbbpofafpmklejenkgnjfcdi"
            chromeAppPreferences="" />
          <protocolHandler enabled="true" platforms="(Macintosh|Windows NT|Linux|Android|iPhone).*((Firefox/((5[2-9]|[6789][0-9]|1[2-9]|[2-9])|\d\d\d))|(Chrome/((4[2-9]|[56789][0-9]|1[2-9]|[2-9]|[2-9]|[2-9])|\d\d\d))|(CriOS/)|(FxiOS/))|(Mobile/)|Macintosh.*Version/(1[2-9]|[2-9][0-9]).*Safari/"
            skipDoubleHopCheckWhenDisabled="false" />
          <browserExtension enabled="true" timeout="6000" retries="2" />
        </pluginAssistant>
        <userInterface autoLaunchDesktop="false" multiClickTimeout="3"
          enableAppsFolderView="true" categoryViewCollapsed="true" moveAppToUncategorized="false"
          showActivityManager="true" showFirstTimeUse="true" preventIcaDownloads="false">
          <workspaceControl enabled="false" autoReconnectAtLogon="false"
            logoffAction="none" showReconnectButton="false" showDisconnectButton="false" />
          <receiverConfiguration enabled="false" downloadURL="ServiceRecord/GetDocument/receiverconfig.cr" />
          <uiViews showDesktopsView="true" showAppsView="true" defaultView="auto"
            showHomeTab="true" alwaysShowTabs="false" appsViewTab="all"
            defaultCategoryName="" />
          <appShortcuts enabled="false" allowSessionReconnect="false" />
          <progressiveWebApp enabled="false" showInstallPrompt="false" />
          <branding backgroundColor="" textColor="" linkColor="" headerLogo=""
            logonLogo="" />
        </userInterface>
        <appProtection enabled="" />
        <plugins>
          <clear />
        </plugins>
        <pinnedLinks enabled="false">
          <clear />
        </pinnedLinks>
        <userNotifications url="Home/AdminNotificationService" />
        <ticketService>
          <supportedTickets>
            <clear />
            <ticket type="LogServer" />
          </supportedTickets>
        </ticketService>
      </clientSettings>
    </webReceiver>
    <logger duplicateLimit="10" duplicateInterval="00:01:00">
      <logConsumers>
        <clear />
        <add name="eventLogWriter" factory="Citrix.DeliveryServices.Logging.WindowsEventLoggerFactory, Citrix.DeliveryServices.Logging, Version=3.33.0.0, Culture=neutral, PublicKeyToken=e8b77d454fa2a856" path="citrix.deliveryservices/windowsEventLogger" />
      </logConsumers>
    </logger>
    <windowsEventLogger sourceName="Citrix Receiver for Web" />
    <cryptography>
      <signatures>
        <clear />
        <add name="rsa-sha1" class="Citrix.DeliveryServices.Security.Cryptography.Signature.XmlSignature10, Citrix.DeliveryServices.Security, Version=3.33.0.0, Culture=neutral, PublicKeyToken=e8b77d454fa2a856" />
        <add name="rsa-sha1-2" class="Citrix.DeliveryServices.Security.Cryptography.Signature.XmlSignature10, Citrix.DeliveryServices.Security, Version=3.33.0.0, Culture=neutral, PublicKeyToken=e8b77d454fa2a856"
