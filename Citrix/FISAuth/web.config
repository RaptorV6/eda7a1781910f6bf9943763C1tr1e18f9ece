    <credentialWallet wallet="defaultCredentialWallet" />
    <credentialWalletClient>
      <clientEndpoint uri="net.pipe://localhost/Citrix/CredentialWalletService" authenticationMode="windows" clientOpenTimeout="00:01:00" clientCloseTimeout="00:00:10" clientSendTimeout="00:01:00" />
    </credentialWalletClient>
    <dataStoreClient Enabled="True">
      <clientEndpoint uri="net.pipe://localhost/Citrix/StoreFrontDataStore" authenticationMode="windows" clientOpenTimeout="00:01:00" clientCloseTimeout="00:00:10" clientSendTimeout="00:01:00" />
    </dataStoreClient>
    <authentication logging="None" hideAccountErrors="false" collectFasEvidence="false" />
    <delegatedDirectoryClaimFactory enabled="true">
      <clientEndpoint uri="net.pipe://localhost/Citrix/DirectoryClaimFactory"
        wsSecurity="false" authenticationMode="windows" clientOpenTimeout="00:01:00"
        clientCloseTimeout="00:00:10" clientSendTimeout="00:01:00" portSharingEnabled="true">
        <clientCertificate thumbprint="0" storeName="My" storeLocation="LocalMachine" />
      </clientEndpoint>
      <requiredProperties>
        <clear />
        <add property="displayName" />
        <add property="userPrincipalName" />
        <add property="mail" />
        <add property="objectGUID" />
      </requiredProperties>
    </delegatedDirectoryClaimFactory>
    <delegatedKerberosAuthentication>
      <clientEndpoint uri="net.pipe://localhost/Citrix/Authentication/Kerberos" authenticationMode="windows" clientOpenTimeout="00:01:00" clientCloseTimeout="00:00:10" clientSendTimeout="00:01:00" />
    </delegatedKerberosAuthentication>
    <authenticationService tokenServiceId="7ddeadb6-aeb0-43eb-a1d6-63bb70ed7389">
      <tokenValidationManager>
        <tokenValidationServices>
          <clear />
          <add id="default" verifyingTokenServiceId="c9867bfd-6bd9-4be8-a1ca-db143c6107dc">
            <claims>
              <clear />
              <add name="SIDClaimType" type="http://schemas.xmlsoap.org/ws/2005/05/identity/claims/sid" />
              <add name="DirectoryClaimType" type="uri:citrix.deliveryservices.claim.directoryproperties" />
              <add name="CitrixUserClaimType" type="uri:citrix.deliveryservices.claim.citrixUser" />
            </claims>
          </add>
        </tokenValidationServices>
      </tokenValidationManager>
      <authenticationProtocolChoices>
        <clear />
        <add protocol="ExplicitForms" relativeUrl="ExplicitForms/Start"
          enabled="true" path="citrix.deliveryservices/explicitAuthentication">
          <properties>
            <clear />
          </properties>
        </add>
        <add protocol="Forms-Saml" relativeUrl="SamlForms/Start" enabled="false"
          path="citrix.deliveryservices/samlForms">
          <properties>
            <clear />
          </properties>
        </add>
        <add protocol="IntegratedWindows" relativeUrl="Integrated/Authenticate"
          enabled="false" path="citrix.deliveryservices/integratedWindowsAuthentication">
          <properties>
            <clear />
          </properties>
        </add>
        <add protocol="CitrixFederation" relativeUrl="CitrixFederation/Authenticate"
          enabled="true" path="citrix.deliveryservices/citrixFederationAuthentication">
          <properties>
            <clear />
          </properties>
        </add>
        <add protocol="Certificate" relativeUrl="Certificate/Authenticate"
          enabled="false" path="citrix.deliveryservices/certificateAuthentication">
          <properties>
            <clear />
          </properties>
        </add>
        <add protocol="HttpBasic" relativeUrl="HttpBasic/Authenticate"
          enabled="false" path="citrix.deliveryservices/httpBasicAuthentication">
          <properties>
            <clear />
          </properties>
        </add>
        <add protocol="CitrixAGBasic" relativeUrl="CitrixAGBasic/Authenticate"
          enabled="false" path="citrix.deliveryservices/citrixAGBasicAuthentication">
          <properties>
            <clear />
            <add name="requestFilter" value="CitrixAGBasicRequestFilterPasswordRequired" />
          </properties>
        </add>
        <add protocol="CitrixAGBasicNoPassword" relativeUrl="CitrixAGBasic/AuthenticateNoPassword"
          enabled="true" path="citrix.deliveryservices/citrixAGBasicAuthentication">
          <properties>
