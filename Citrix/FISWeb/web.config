      <section name="tokenManager" type="Citrix.DeliveryServices.Security.Tokens.Configuration.TokenManagerSection, Citrix.DeliveryServices.Security, Version=3.33.0.0, Culture=neutral, PublicKeyToken=e8b77d454fa2a856" />
